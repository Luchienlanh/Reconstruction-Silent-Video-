{
  "data": {
    "train_manifest": "datasets_l2t_arch_50k/train.jsonl",
    "val_manifest": "datasets_l2t_arch_50k/val.jsonl"
  },
  "text": {
    "symbols": "abcdefghijklmnopqrstuvwxyz '"
  },
  "model": {
    "type": "text_only",
    "hidden_dim": 192,
    "num_heads": 4,
    "text_layers": 3,
    "decoder_layers": 3,
    "ffn_dim": 768,
    "dropout": 0.2
  },
  "training": {
    "output_dir": "checkpoints_l2t_arch_text_only",
    "batch_size": 16,
    "epochs": 25,
    "lr": 0.0001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 2,
    "device": "cuda",
    "amp": true,
    "limit_samples": 0
  }
}

